# Discord
DISCORD_TOKEN=
# Optional: restrict to a channel id
DISCORD_ALLOW_CHANNEL_ID=

# Telegram
TELEGRAM_TOKEN=

# Agent command (stdio ACP)
# Examples:
#   npx @zed-industries/codex-acp@latest
#   npx @zed-industries/claude-agent-acp@latest
#   gemini --experimental-acp
ACP_AGENT_COMMAND=
ACP_AGENT_ARGS=

# Workspace root for fs/terminal tool calls (absolute path)
WORKSPACE_ROOT=/tmp/cli-gateway-workspace

# DB path
DB_PATH=.data/gateway.db

# Scheduler
SCHEDULER_ENABLED=true
